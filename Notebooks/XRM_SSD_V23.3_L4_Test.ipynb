import time
import numpy as np
from tqdm import tqdm
import torch

# 假設的測試 pipeline（替換成 XRM-SSD 實際 API）
def run_xrm_ssd_inference(model, inputs, num_runs=100):
    latencies = []
    for _ in tqdm(range(num_runs)):
        start = time.perf_counter()
        output = model.inference(inputs)  # 或 model.optic_nerve_process(inputs)
        end = time.perf_counter()
        latencies.append((end - start) * 1000)  # ms
    
    return {
        "avg_latency_ms": np.mean(latencies),
        "p95_ttft_ms": np.percentile(latencies, 95),
        "throughput_tps": len(inputs) / np.mean(latencies) * 1000,  # 粗估 TPS
        "gpu_util": torch.cuda.utilization()
    }

# 準備測試資料（例如影像序列、影片 frame，或文字 prompt，依 XRM-SSD 用途）
test_inputs = [torch.randn(1, 3, 224, 224).cuda() for _ in range(50)]  # 範例影像輸入

results = run_xrm_ssd_inference(model, test_inputs, num_runs=200)

print("=== XRM-SSD V23.3 + TensorRT-LLM on L4 ===")
print(f"Avg Latency: {results['avg_latency_ms']:.2f} ms")
print(f"P95 TTFT: {results['p95_ttft_ms']:.2f} ms")
print(f"Throughput (TPS): {results['throughput_tps']:.1f}")
print(f"GPU Util: {results['gpu_util']}%")

